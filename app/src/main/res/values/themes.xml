<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.CampusCore" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_indigo</item>
        <item name="colorPrimaryDark">@color/primary_indigo_dark</item>
        <item name="colorSecondary">@color/secondary_cyan</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.CampusCore" parent="Base.Theme.CampusCore" />

    <style name="Theme.CampusCore.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/primary_indigo</item>
        <item name="android:statusBarColor">@color/primary_indigo</item>
        <item name="android:navigationBarColor">@color/primary_indigo</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>

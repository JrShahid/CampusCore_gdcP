<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@color/login_input_fill"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/monitor_activity_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/login_heading"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/monitor_activity_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/login_body" />

    <TextView
        android:id="@+id/monitor_activity_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/login_body" />
</LinearLayout>

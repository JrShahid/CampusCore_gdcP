<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/login_card_background"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/attempt_question_index"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/login_body"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/attempt_question_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/login_heading"
        android:textSize="18sp"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/attempt_question_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />
</LinearLayout>

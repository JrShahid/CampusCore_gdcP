<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@color/login_input_fill"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/material_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/login_heading"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/material_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/login_body"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/material_file_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/login_heading"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/material_uploaded_at"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/login_body"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/material_view_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/login_button"
            android:text="@string/study_material_view_button"
            android:textAllCaps="false"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/material_download_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="@color/login_heading"
            android:text="@string/study_material_download_button"
            android:textAllCaps="false"
            android:textColor="@color/white" />
    </LinearLayout>
</LinearLayout>
